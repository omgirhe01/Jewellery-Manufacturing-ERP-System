ACCESS_TOKEN_EXPIRE_MINUTES=480

# Weighing Scale
SCALE_SIMULATION_MODE=true
SCALE_PORT=COM3
SCALE_BAUDRATE=9600

# App
APP_NAME=Jewellery ERP
APP_VERSION=1.0.0
DEBUG=true
